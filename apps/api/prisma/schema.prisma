// Vertik12 — data model.
//
// Dev database is SQLite (zero config). SQLite has no native enums, so
// enum-like fields are Strings validated by the Zod schemas in
// @vertik12/shared (single source of truth). To move to PostgreSQL:
// change `provider` to "postgresql", set DATABASE_URL, and optionally
// promote the commented value sets to real enums.
//
// All money fields are integer minor units (cents) to avoid float errors.

generator client {
  provider = "prisma-client-js"
  // "native" for local dev; "rhel-openssl-3.0.x" is the AWS Lambda
  // (Amazon Linux 2023) engine bundled by scripts/build-lambda.mjs.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================== identity ==============================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         String // SUPER_ADMIN | ADMIN | REGISTRAR | TEACHER | ACCOUNTANT | STUDENT | PARENT
  isActive     Boolean  @default(true)
  /// True while the account still uses a temporary/admin-issued password;
  /// the web app forces a password change before anything else.
  mustChangePassword Boolean @default(false)
  /// Last time this user opened the Announcements page — announcements
  /// created after this moment count as "unread" for the sidebar badge.
  announcementsSeenAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student          Student?
  staff            Staff?
  guardian         Guardian?
  announcements    Announcement[]
  refreshTokens    RefreshToken[]
  sentMessages     Message[] @relation("sentMessages")
  receivedMessages Message[] @relation("receivedMessages")
  dailyVisits      DailyVisit[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
}

// ============================== people ==============================

model Student {
  id           String    @id @default(cuid())
  admissionNo  String    @unique // e.g. VRT-2026-0001
  userId       String?   @unique
  user         User?     @relation(fields: [userId], references: [id])
  firstName    String
  lastName     String
  dateOfBirth  DateTime
  gender       String // MALE | FEMALE | OTHER
  gradeLevel   String // K | 1..12
  status       String    @default("ACTIVE") // ACTIVE | GRADUATED | TRANSFERRED | WITHDRAWN | SUSPENDED
  email        String?
  phone        String?
  // Full postal address — every part optional.
  addressLine1 String? // street
  addressLine2 String? // unit / apartment / suite
  city         String?
  state        String? // state / province / region
  postalCode   String? // ZIP / postal code
  country      String?
  nationality  String? // country of citizenship
  placeOfBirth String?
  bloodGroup   String?
  medicalNotes String?
  photoUrl     String?
  /// Uploaded/captured photo in the document store (preferred over photoUrl).
  photoRef     String?
  photoType    String? // mime type of the stored photo
  admittedAt   DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  guardians             StudentGuardian[]
  enrollments           Enrollment[]
  attendance            AttendanceRecord[]
  examResults           ExamResult[]
  invoices              Invoice[]
  assignmentSubmissions AssignmentSubmission[]
  documents             StudentDocument[]

  @@index([gradeLevel, status])
}

/// Scanned/photographed paperwork on the student's file: guardian ID,
/// birth certificate, transfer letter… Captured by webcam or uploaded at
/// registration (or later); bodies live in the document store.
model StudentDocument {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  label        String // e.g. "Guardian ID — Father", "Birth certificate"
  fileRef      String // document-store key
  fileName     String
  fileType     String // mime type
  uploadedById String? // user id (registrar/admin)
  createdAt    DateTime @default(now())

  @@index([studentId])
}

model Guardian {
  id         String  @id @default(cuid())
  userId     String? @unique
  user       User?   @relation(fields: [userId], references: [id])
  firstName  String
  lastName   String
  email      String?
  phone      String
  occupation String?

  students StudentGuardian[]
}

model StudentGuardian {
  studentId  String
  guardianId String
  relation   String // Mother | Father | Guardian | ...
  isPrimary  Boolean @default(false)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian   Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@id([studentId, guardianId])
}

model Staff {
  id             String   @id @default(cuid())
  staffNo        String   @unique // e.g. VRT-EMP-0001
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  staffType      String // TEACHING | NON_TEACHING
  designation    String
  department     String?
  phone          String?
  qualifications String?
  status         String   @default("ACTIVE") // ACTIVE | ON_LEAVE | TERMINATED | RESIGNED
  joinDate       DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  homeroomOf      ClassRoom[]
  classSubjects   ClassSubject[]
  timetableSlots  TimetableSlot[]
  salaryStructure SalaryStructure?
  payslips        Payslip[]
}

// ============================== academics ==============================

model AcademicYear {
  id        String   @id @default(cuid())
  name      String   @unique // "2026-2027"
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)

  terms          Term[]
  classRooms     ClassRoom[]
  enrollments    Enrollment[]
  feeStructures  FeeStructure[]
  calendarEvents CalendarEvent[]
}

model Term {
  id             String       @id @default(cuid())
  name           String // "Term 1"
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  startDate      DateTime
  endDate        DateTime

  exams Exam[]

  @@unique([academicYearId, name])
}

model ClassRoom {
  id                String       @id @default(cuid())
  name              String // "Grade 5 — A", "KG1 — B (West Campus)"
  gradeLevel        String // K | 1..12
  section           String       @default("A")
  /// Optional campus/branch label for multi-branch schools.
  branch            String?
  capacity          Int          @default(30)
  academicYearId    String
  academicYear      AcademicYear @relation(fields: [academicYearId], references: [id])
  homeroomTeacherId String?
  homeroomTeacher   Staff?       @relation(fields: [homeroomTeacherId], references: [id])

  enrollments    Enrollment[]
  classSubjects  ClassSubject[]
  attendance     AttendanceRecord[]
  timetableSlots TimetableSlot[]

  // Multiple sections/branches per grade are allowed; only the display
  // name must be unique within a year.
  @@unique([academicYearId, name])
}

/// Admin-configured grade levels. Grade naming varies by country (KG1,
/// Year 7, Form 2, A-Level…), so the administration defines the school's
/// own ladder instead of a hard-coded K-12. `code` is what Student /
/// ClassRoom / Subject / FeeStructure rows store in their gradeLevel field.
model GradeLevelDef {
  id        String @id @default(cuid())
  code      String @unique // "K", "1", "KG1", "Y7"…
  name      String // display label: "Kindergarten", "Grade 1", "Year 7"…
  sortOrder Int    @default(0)
}

model Subject {
  id          String  @id @default(cuid())
  code        String  @unique // "MATH", "CALC12"
  name        String
  description String?
  /// Grade this subject is taught in. Null = offered in all grades.
  /// Subjects are created per-grade by the SUPER_ADMIN.
  gradeLevel  String?

  classSubjects  ClassSubject[]
  examResults    ExamResult[]
  timetableSlots TimetableSlot[]
  attendance     AttendanceRecord[]
  lessonPlans    LessonPlan[]
}

/// Curriculum lesson plans, per grade × subject. The administration (or a
/// teacher) publishes the plan every teacher of that grade/subject follows;
/// week numbers order the plan through the term. Bodies stay in SQL (they
/// are structured text, not blobs); optional worksheet files go to the
/// document store like assignment attachments.
model LessonPlan {
  id          String   @id @default(cuid())
  gradeLevel  String // GradeLevelDef.code
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  /// Week of the term this plan covers (1-52); null = general/unscheduled.
  week        Int?
  title       String
  objectives  String // what students should learn
  materials   String? // resources / teaching aids
  activities  String // lesson flow: intro, main activity, practice…
  assessment  String? // how learning is checked
  notes       String?
  /// Workflow: DRAFT (author-private) → PENDING (teacher submitted, awaits
  /// admin approval) → PUBLISHED (live for all teachers) | REJECTED (sent
  /// back with a note). Admin-authored plans publish directly.
  status      String   @default("PUBLISHED")
  reviewNote   String? // admin's note on approve/reject
  reviewedById String? // user id of the reviewing admin
  reviewedAt   DateTime?
  attachmentRef  String?
  attachmentName String?
  attachmentType String?
  createdById String // user id (admin or teacher)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([gradeLevel, subjectId])
  @@index([status])
}

model ClassSubject {
  id          String    @id @default(cuid())
  classRoomId String
  classRoom   ClassRoom @relation(fields: [classRoomId], references: [id], onDelete: Cascade)
  subjectId   String
  subject     Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacherId   String?
  teacher     Staff?    @relation(fields: [teacherId], references: [id])

  assignments Assignment[]

  @@unique([classRoomId, subjectId])
}

// ============================== assignments ==============================

/// Homework/assignment a teacher sends to one of their classes. Parents see
/// it in the portal and submit on their child's behalf.
model Assignment {
  id             String       @id @default(cuid())
  classSubjectId String
  classSubject   ClassSubject @relation(fields: [classSubjectId], references: [id], onDelete: Cascade)
  title          String
  instructions   String
  dueDate        DateTime
  createdById    String // user id of the teacher
  createdAt      DateTime     @default(now())
  /// Optional teacher attachment (PDF/JPG/DOC). The file body lives in the
  /// document store; SQL keeps only the reference + display metadata.
  attachmentRef  String?
  attachmentName String?
  attachmentType String? // mime type

  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id            String     @id @default(cuid())
  assignmentId  String
  assignment    Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  submittedById String // user id (parent)
  /// Key of the submission body in the document store (MongoDB/DynamoDB in
  /// production, in-process store in dev) — large content stays out of SQL.
  contentRef    String
  linkUrl       String?
  /// Optional uploaded document (PDF/JPG/DOC) — body in the document store.
  attachmentRef  String?
  attachmentName String?
  attachmentType String? // mime type
  submittedAt   DateTime   @default(now())
  feedback      String? // teacher's feedback after review
  grade         String?

  @@unique([assignmentId, studentId])
}

model Enrollment {
  id             String       @id @default(cuid())
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classRoomId    String
  classRoom      ClassRoom    @relation(fields: [classRoomId], references: [id])
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  rollNo         Int?
  status         String       @default("ENROLLED") // ENROLLED | PROMOTED | COMPLETED | WITHDRAWN
  createdAt      DateTime     @default(now())

  @@unique([studentId, academicYearId])
}

/// One recurring period in the weekly timetable: this class studies this
/// subject with this teacher, this weekday, from this time to that time.
///
/// The academic year is not stored here — it is the year of `classRoom`,
/// which keeps a single source of truth. Every conflict check therefore
/// filters on `classRoom.academicYearId`: two slots can only clash if they
/// belong to the same school year.
///
/// Three clashes are refused when a slot is created or moved (see
/// modules/schedule/schedule.service.ts):
///   1. the class is already studying something else at that time,
///   2. the teacher is already teaching another class at that time,
///   3. the physical room is already taken at that time.
model TimetableSlot {
  id          String    @id @default(cuid())
  classRoomId String
  classRoom   ClassRoom @relation(fields: [classRoomId], references: [id], onDelete: Cascade)
  subjectId   String
  subject     Subject   @relation(fields: [subjectId], references: [id])
  teacherId   String?
  teacher     Staff?    @relation(fields: [teacherId], references: [id])
  dayOfWeek   String // MONDAY..SUNDAY
  startTime   String // "08:00" (24h HH:MM — string-comparable and sortable)
  endTime     String // "08:45"
  /// Physical room/lab/hall. Two slots in the same room at the same time clash.
  room        String?
  /// Free-text note shown on the teacher's schedule ("double period", "lab week B"…).
  note        String?
  createdById String? // user id (admin/registrar) who placed the slot
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  changeRequests ScheduleChangeRequest[]

  // Conflict lookups scan by day, then by the party being checked.
  @@index([classRoomId, dayOfWeek])
  @@index([teacherId, dayOfWeek])
}

/// A teacher asking the registrar/admin to move or drop one of their periods
/// ("I can't make Tuesday 10:00"). PENDING requests appear in the
/// registrar's inbox; approving a CHANGE request applies the proposed day/
/// time to the slot itself — re-running the same conflict checks — so the
/// timetable can never be broken by an approval.
model ScheduleChangeRequest {
  id       String        @id @default(cuid())
  slotId   String
  slot     TimetableSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  /// Staff row of the teacher who filed it (the slot's teacher).
  staffId  String
  /// User id of the requester — who to notify on review.
  requestedById String
  /// CHANGE = move to the proposed day/time · SWAP = hand the period to
  /// another teacher · CANCEL = drop the period entirely.
  kind     String        @default("CHANGE")
  reason   String
  /// Proposed replacement slot (CHANGE only) — all null = "you decide".
  proposedDayOfWeek String?
  proposedStartTime String?
  proposedEndTime   String?
  /// Staff id of the covering teacher (SWAP only).
  proposedTeacherId String?
  status       String    @default("PENDING") // PENDING | APPROVED | REJECTED | CANCELLED
  reviewNote   String? // registrar's note on approve/reject
  reviewedById String? // user id of the reviewing registrar/admin
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([status])
  @@index([staffId, status])
}

// ============================== school calendar ==============================

/// The school calendar every portal reads: term dates, holidays, exam
/// windows, PTA meetings, sports days, staff training…
///
/// Anyone signed in can propose an event; only the administration publishes.
/// An event created by an admin goes straight to PUBLISHED, everyone else's
/// lands as PENDING in the admin's review queue (same shape as the lesson
/// plan workflow). `audience` then decides who sees a published event —
/// parents never see a staff-training day unless it is addressed to ALL.
model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  /// HOLIDAY | EXAM | MEETING | ACTIVITY | SPORTS | TERM | TRAINING | DEADLINE | OTHER
  category    String   @default("OTHER")
  /// ALL | STAFF | STUDENTS | PARENTS — who the event is for.
  audience    String   @default("ALL")
  /// Inclusive date range, both normalized to midnight UTC. A single-day
  /// event stores the same date twice, so every query is a range overlap.
  startDate   DateTime
  endDate     DateTime
  /// All-day events ignore the times; timed events render "09:00 — 11:30".
  allDay      Boolean  @default(true)
  startTime   String? // "09:00"
  endTime     String? // "11:30"
  location    String?
  /// Optional link to the academic year the event belongs to, so archived
  /// years keep their calendar and the current year filters cleanly.
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
  /// PUBLISHED (live) | PENDING (proposed, awaiting admin) | REJECTED.
  status      String   @default("PUBLISHED")
  reviewNote   String?
  reviewedById String?
  reviewedAt   DateTime?
  createdById String // user id of the author (any role)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // The calendar is always read as "everything overlapping this window".
  @@index([startDate, endDate])
  @@index([status])
}

/// Admin-managed assessment types (Term Exam, Final Exam, Quiz, …).
/// Exam.category stores the type's name; defaults are seeded.
model ExamType {
  id        String @id @default(cuid())
  name      String @unique
  sortOrder Int    @default(0)
}

// ============================== attendance ==============================

model AttendanceRecord {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classRoomId String
  classRoom   ClassRoom @relation(fields: [classRoomId], references: [id])
  /// Attendance is per subject/period: teachers mark the subject they teach.
  /// Null = general/homeroom attendance (admin/registrar).
  subjectId   String?
  subject     Subject?  @relation(fields: [subjectId], references: [id])
  date        DateTime // normalized to midnight UTC
  status      String // PRESENT | ABSENT | LATE | EXCUSED
  note        String?
  markedById  String? // user id of the teacher who marked it
  createdAt   DateTime  @default(now())

  @@unique([studentId, date, subjectId])
  @@index([classRoomId, date])
  @@index([studentId, date])
  // Whole-school "attendance today" dashboard counters filter by date alone.
  @@index([date])
}

// ============================== exams & grades ==============================

model Exam {
  id        String    @id @default(cuid())
  name      String
  /// ASSIGNMENT | WEEKLY_TEST | TERM_EXAM | FINAL_EXAM | OTHER
  category  String    @default("OTHER")
  termId    String
  term      Term      @relation(fields: [termId], references: [id], onDelete: Cascade)
  weight    Float     @default(100) // % contribution to the final grade
  startDate DateTime?
  createdBy String? // user id (teacher or admin)
  createdAt DateTime  @default(now())

  results     ExamResult[]
  submissions ResultSubmission[]
}

/// Teacher → Registrar result sign-off. No row = DRAFT (teacher can edit).
/// SUBMITTED locks the marks pending review; APPROVED locks them for good;
/// REJECTED reopens editing until the teacher resubmits.
model ResultSubmission {
  id           String    @id @default(cuid())
  examId       String
  exam         Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  classRoomId  String
  subjectId    String
  teacherId    String? // staff id of the submitting teacher
  status       String    @default("SUBMITTED") // SUBMITTED | APPROVED | REJECTED
  note         String? // registrar's note on approve/reject
  submittedAt  DateTime  @default(now())
  reviewedAt   DateTime?
  reviewedById String? // user id of the registrar/admin

  @@unique([examId, classRoomId, subjectId])
}

model ExamResult {
  id        String  @id @default(cuid())
  examId    String
  exam      Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])
  marks     Float
  maxMarks  Float   @default(100)
  grade     String // computed letter grade, e.g. "A-"
  remark    String?

  @@unique([examId, studentId, subjectId])
  // Student profile / parent portal read results by student, not by exam.
  @@index([studentId])
}

// ============================== finance ==============================

model FeeStructure {
  id             String       @id @default(cuid())
  name           String
  gradeLevel     String? // null = applies to all grades
  amount         Int // cents
  frequency      String // ONE_TIME | MONTHLY | TERMLY | ANNUAL
  description    String?
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  isActive       Boolean      @default(true)

  invoiceItems InvoiceItem[]
}

model Invoice {
  id        String   @id @default(cuid())
  number    String   @unique // INV-2026-000123
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  currency  String   @default("USD")
  status    String   @default("ISSUED") // DRAFT | ISSUED | PARTIALLY_PAID | PAID | OVERDUE | VOID
  issueDate DateTime @default(now())
  dueDate   DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items    InvoiceItem[]
  payments Payment[]

  @@index([studentId, status])
}

model InvoiceItem {
  id             String        @id @default(cuid())
  invoiceId      String
  invoice        Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description    String
  amount         Int // cents
  feeStructureId String?
  feeStructure   FeeStructure? @relation(fields: [feeStructureId], references: [id])
}

model Payment {
  id          String    @id @default(cuid())
  invoiceId   String
  invoice     Invoice   @relation(fields: [invoiceId], references: [id])
  amount      Int // cents
  method      String // CARD | BANK_TRANSFER | CASH | CHEQUE | MOBILE_MONEY
  status      String    @default("PENDING") // PENDING | SUCCEEDED | FAILED | REFUNDED
  provider    String    @default("MANUAL") // MANUAL | STRIPE | MOCK
  providerRef String? // Stripe session/intent id or manual receipt no
  /// Free-text note the cashier attaches while collecting (shown on the receipt).
  note        String?
  paidAt      DateTime?
  recordedBy  String? // user id
  /// Refunds are SUPER_ADMIN-only; the original row is kept for the audit trail.
  refundedAt   DateTime?
  refundedBy   String? // user id of the super admin
  refundReason String?
  createdAt   DateTime  @default(now())

  @@index([invoiceId])
  // Checkout confirmations (webhook + redirect) look payments up by session id.
  @@index([providerRef])
}

// ============================== payroll ==============================

model SalaryStructure {
  id            String   @id @default(cuid())
  staffId       String   @unique
  staff         Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  basicSalary   Int // cents per pay period
  /// MONTHLY | BIWEEKLY — how often this staff member is paid.
  payFrequency  String   @default("MONTHLY")
  currency      String   @default("USD")
  allowances    String   @default("[]") // JSON: [{ name, amount }]
  deductions    String   @default("[]") // JSON: [{ name, amount }]
  effectiveFrom DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PayrollRun {
  id         String    @id @default(cuid())
  month      Int // 1-12
  year       Int
  status     String    @default("DRAFT") // DRAFT | APPROVED | PAID
  notes      String?
  createdBy  String? // user id
  approvedAt DateTime?
  paidAt     DateTime?
  createdAt  DateTime  @default(now())

  payslips Payslip[]

  @@unique([month, year])
}

model Payslip {
  id         String     @id @default(cuid())
  runId      String
  run        PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  staffId    String
  staff      Staff      @relation(fields: [staffId], references: [id])
  basicSalary Int
  allowances String // JSON snapshot: [{ name, amount }]
  deductions String // JSON snapshot: [{ name, amount }]
  /// One-off bonus the admin adds to this payslip while the run is a draft.
  bonus      Int    @default(0)
  gross      Int
  totalDeductions Int
  net        Int
  currency   String     @default("USD")
  status     String     @default("PENDING") // PENDING | PAID
  paidAt     DateTime?

  @@unique([runId, staffId])
}

// ============================== administration ==============================

/// Immutable trail of every mutating API call (who did what, when).
/// Written fire-and-forget by the audit middleware; read by SUPER_ADMIN.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String?
  role      String?
  method    String // POST | PUT | PATCH | DELETE
  path      String // e.g. /api/v1/students/abc123
  action    String // human label, e.g. "students.create"
  status    Int // HTTP status of the response
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

/// One row per user per day with any authenticated activity — powers the
/// admin dashboard's "visitors" counters and Administration › Visitors.
/// Written fire-and-forget by the auth middleware (throttled in-process,
/// so ~one write per user per day). Client details are captured from the
/// first request of the day: IP (X-Forwarded-For aware), country (from the
/// CDN's viewer-country header when present) and the parsed user agent.
model DailyVisit {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   String
  date   DateTime // normalized to midnight UTC
  ip        String?
  country   String? // ISO-3166 alpha-2 from CloudFront/Cloudflare headers, "Local" for loopback
  browser   String? // e.g. "Chrome 126"
  os        String? // e.g. "Windows", "iOS"
  device    String? // Desktop | Mobile | Tablet
  userAgent String? // raw User-Agent, kept for anything the parser misses

  @@unique([userId, date])
  @@index([date])
}

/// Singleton (id = "school") — profile & policies editable by SUPER_ADMIN.
model SchoolSettings {
  id                    String  @id @default("school")
  schoolName            String  @default("Vertik12 Academy")
  motto                 String?
  logoUrl               String?
  address               String?
  phone                 String?
  email                 String?
  currency              String  @default("USD")
  timezone              String  @default("UTC")
  passwordMinLength     Int     @default(8)
  sessionTimeoutMinutes Int     @default(60)
  /// Discount applied when a family pays the whole year at once (0-100).
  yearlyDiscountPercent Float   @default(0)
  /// When true, teachers can no longer add or modify lesson plans — the
  /// administration locks the curriculum once it is complete and re-opens
  /// editing when revisions are allowed. Admins are never locked out.
  lessonPlansLocked     Boolean @default(false)
  updatedAt             DateTime @updatedAt
}

/// Singleton (id = "mail") — the school's own outgoing mail server.
///
/// Vertik12 ships to many schools, each sending from their own domain, so
/// SMTP cannot live in environment variables baked into the deployment.
/// The Super Admin configures it in the app; the mailer reads this row and
/// falls back to SMTP_* env vars (then to simulated sends) when it is empty,
/// so existing installations and local development keep working untouched.
///
/// The password is stored as AES-256-GCM ciphertext (see lib/secret-box.ts)
/// and is never returned by the API — reads report `hasPassword` instead.
model MailSettings {
  id       String  @id @default("mail")
  /// Master switch: off = ignore this row entirely (fall back to env/simulated).
  enabled  Boolean @default(false)
  host     String?
  port     Int     @default(587)
  /// Implicit TLS from the first byte (port 465). Port 587 uses STARTTLS,
  /// which nodemailer negotiates automatically with secure = false.
  secure   Boolean @default(false)
  username String?
  /// AES-256-GCM ciphertext. Never leaves the API process.
  passwordEnc String?
  /// Envelope sender — the school's own domain, e.g. "St Mary's" <no-reply@stmarys.edu>.
  fromName  String?
  fromEmail String?
  replyTo   String?
  /// Outcome of the last "send test email", so the admin can see at a glance
  /// whether delivery actually works rather than guessing.
  lastTestAt    DateTime?
  lastTestOk    Boolean?
  lastTestError String?
  updatedAt DateTime @updatedAt
}

/// Admin-configurable grading scale (Super Admin › Grading). Percentages are
/// matched against the highest `minPercent` they reach, e.g. 95 → A+ if the
/// school sets A+ at 95, or → A where the country uses 90 = A.
model GradeBand {
  id         String @id @default(cuid())
  letter     String // "A+", "A", "B-", …
  minPercent Float // lower bound (inclusive), 0-100
  points     Float // GPA points for this band
  sortOrder  Int // display order, highest band first

  @@unique([minPercent])
}

/// Registrar sign-off on a term report card before it is printed/released.
model ReportCardApproval {
  id           String   @id @default(cuid())
  studentId    String
  termId       String
  approvedById String
  approvedAt   DateTime @default(now())

  @@unique([studentId, termId])
}

// ============================== messaging ==============================

/// Internal email-like messaging between staff accounts
/// (registrar ↔ teachers ↔ administrators).
model Message {
  id          String    @id @default(cuid())
  senderId    String
  sender      User      @relation("sentMessages", fields: [senderId], references: [id])
  recipientId String
  recipient   User      @relation("receivedMessages", fields: [recipientId], references: [id])
  subject     String
  body        String
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([recipientId, readAt])
  @@index([senderId])
}

// ============================== communication ==============================

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  audience  String   @default("ALL") // ALL | STAFF | STUDENTS | PARENTS
  pinned    Boolean  @default(false)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
}
