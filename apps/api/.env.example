# Copy to .env and adjust.

# SQLite for zero-config local development.
# PRODUCTION: PostgreSQL. Run `npm run db:use:postgres` once, then set e.g.
#   DATABASE_URL="postgresql://vertik12:vertik12@localhost:5432/vertik12"   (docker compose up -d)
#   DATABASE_URL="postgresql://user:pass@<rds-endpoint>:5432/vertik12"      (AWS RDS)
DATABASE_URL="file:./dev.db"

# Document store for unstructured payloads (assignment submissions, documents).
#   local    → JSON files in apps/api/.docstore (dev default, zero config)
#   mongodb  → set MONGODB_URI (+ optional MONGODB_DB, default "vertik12")
#   dynamodb → set DYNAMODB_TABLE (+ AWS credentials/region from the runtime).
#              Documents larger than ~350 KB (DynamoDB caps items at 400 KB)
#              are stored as JSON in S3 — set DOCUMENTS_BUCKET for that.
DOCUMENT_STORE=local
MONGODB_URI=
MONGODB_DB=vertik12
DYNAMODB_TABLE=vertik12-documents
DOCUMENTS_BUCKET=

PORT=4000
NODE_ENV=development

# Web app origin(s) allowed by CORS, comma-separated
CORS_ORIGIN=http://localhost:3000,http://localhost:3005

# Use long random strings in production (e.g. `openssl rand -hex 64`)
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
# Idle session lifetime: activity rotates the refresh token, so a signed-in
# user who stops using the app is logged out after this long.
JWT_REFRESH_TTL=2h

# Optional: enable real card checkout. Leave blank to use the built-in
# mock provider (payments simulate instantly — great for demos).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Default currency for invoices & payroll (ISO 4217)
DEFAULT_CURRENCY=USD

# Outbound email (welcome emails on registration, paystubs, payroll reports).
#
# PREFERRED: leave these blank and let each school configure its own mail
# server in the app — Administration › Email. That is how Vertik12 is meant
# to be shipped to multiple schools: one deployment per school, each sending
# from its own domain, with no redeploy to change mail settings.
#
# These variables remain as a fallback for when nothing is configured in the
# app (handy for a shared staging relay, and so existing installations keep
# working). With neither set, mail runs in "simulated" mode: messages are
# logged instead of sent, so development works with zero configuration.
# Port 465 = implicit TLS (SMTPS); 587 = STARTTLS.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=no-reply@example.com
SMTP_PASS=
# Optional display From; defaults to SMTP_USER.
SMTP_FROM="Vertik12 <no-reply@example.com>"

# Encrypts the SMTP password an admin saves in Administration › Email.
# Optional — falls back to JWT_ACCESS_SECRET, which production already
# forces you to set. Give it its own value so rotating the JWT secrets
# doesn't invalidate the saved mail password. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MAIL_ENCRYPTION_KEY=
