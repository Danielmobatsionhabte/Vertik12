# Copy to .env and adjust.

# SQLite for zero-config local development.
# PRODUCTION: PostgreSQL. Run `npm run db:use:postgres` once, then set e.g.
#   DATABASE_URL="postgresql://vertik12:vertik12@localhost:5432/vertik12"   (docker compose up -d)
#   DATABASE_URL="postgresql://user:pass@<rds-endpoint>:5432/vertik12"      (AWS RDS)
DATABASE_URL="file:./dev.db"

# Document store for unstructured payloads (assignment submissions, documents).
#   local    → JSON files in apps/api/.docstore (dev default, zero config)
#   mongodb  → set MONGODB_URI (+ optional MONGODB_DB, default "vertik12")
#   dynamodb → set DYNAMODB_TABLE (+ AWS credentials/region from the runtime)
DOCUMENT_STORE=local
MONGODB_URI=
MONGODB_DB=vertik12
DYNAMODB_TABLE=vertik12-documents

PORT=4000
NODE_ENV=development

# Web app origin(s) allowed by CORS, comma-separated
CORS_ORIGIN=http://localhost:3000,http://localhost:3005

# Use long random strings in production (e.g. `openssl rand -hex 64`)
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Optional: enable real card checkout. Leave blank to use the built-in
# mock provider (payments simulate instantly — great for demos).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Default currency for invoices & payroll (ISO 4217)
DEFAULT_CURRENCY=USD
