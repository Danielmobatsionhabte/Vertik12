{
  "name": "@vertik12/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "build:lambda": "node scripts/build-lambda.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:bulk": "tsx scripts/seed-bulk.ts",
    "db:remove:bulk": "tsx scripts/remove-bulk.ts",
    "db:wipe": "tsx scripts/wipe-data.ts",
    "db:studio": "prisma studio",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:use:sqlite": "node scripts/set-db-provider.mjs sqlite && prisma generate",
    "db:use:postgres": "node scripts/set-db-provider.mjs postgresql && prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.637.0",
    "@aws-sdk/client-s3": "^3.637.0",
    "@aws-sdk/lib-dynamodb": "^3.637.0",
    "@prisma/client": "^5.19.1",
    "@types/nodemailer": "^8.0.1",
    "@vertik12/shared": "*",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.8.0",
    "morgan": "^1.10.0",
    "nodemailer": "^9.0.3",
    "serverless-http": "^3.2.0",
    "stripe": "^16.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.15",
    "esbuild": "^0.23.1",
    "prisma": "^5.19.1",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  }
}
